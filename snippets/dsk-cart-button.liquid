{% comment %}
  DSK Credit API – бутон за покупка на изплащане от страницата количка.
  Показва се само при включен dskapi_status, попълнен dskapi_cid и EUR.
  Изисква непразна количка.
{% endcomment %}

{% assign show_dskapi = false %}
{% if settings.dskapi_status and settings.dskapi_cid != blank %}
  {% if shop.currency == 'EUR' %}
    {% assign show_dskapi = true %}
  {% endif %}
{% endif %}

{% assign show_in_editor_preview = false %}
{% if request.design_mode and cart.item_count == 0 %}
  {% assign show_in_editor_preview = true %}
{% endif %}

{% assign should_render_dskapi = false %}
{% if show_dskapi and cart.item_count > 0 %}
  {% assign should_render_dskapi = true %}
{% elsif show_dskapi and show_in_editor_preview %}
  {% assign should_render_dskapi = true %}
{% endif %}

{% if should_render_dskapi %}
  {% assign shop_domain = shop.domain | default: '' %}
  {% assign shop_permanent_domain = shop.permanent_domain | default: '' %}

  {% assign dsk_btn_text = settings.dskapi_btn_text | strip %}
  {% if dsk_btn_text == blank %}
    {% assign dsk_btn_text = 'Купи на кредит от' %}
  {% endif %}
  {% assign dsk_max_w = settings.dskapi_btn_max_width | default: 570 %}
  {% assign dsk_btn_h = settings.dskapi_btn_height | default: 52 %}
  {% assign dsk_btn_r = settings.dskapi_btn_round | default: 14 %}

  <div
    class="dskapi-slot dskapi-slot--cart"
    style="--dskapi-max-width: {{ dsk_max_w }}px; --dskapi-btn-height: {{ dsk_btn_h }}px; --dskapi-btn-radius: {{ dsk_btn_r }}px;"
  >
    {% # theme-check-disable MissingAsset %}
    {{ 'dsk-cart-button.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'dsk-cart-button.js' | asset_url }}" defer></script>
    {% # theme-check-enable MissingAsset %}

    <div
      id="dskapi-cart-button-container"
      data-shop-domain="{{ shop_domain }}"
      data-shop-permanent-domain="{{ shop_permanent_domain }}"
      data-cid="{{ settings.dskapi_cid }}"
    >
      <button
        type="button"
        id="btn_dskapi_cart"
        class="dskapi-btn"
        {% if cart.item_count == 0 %}
          disabled
        {% endif %}
      >
        <span class="dskapi-btn-text">{{ dsk_btn_text | escape }}</span>
        <span class="dskapi-btn-logo">
          <img
            src="{{ 'dsk-logo-color.svg' | asset_url }}"
            alt="Банка ДСК покупки на Кредит"
            width="120"
            height="20"
          >
        </span>
      </button>
    </div>
  </div>
{% endif %}
